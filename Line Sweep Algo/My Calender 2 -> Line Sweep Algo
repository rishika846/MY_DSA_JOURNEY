class MyCalendarTwo {
public:
    map<int,int>map;
    MyCalendarTwo(){
        
    }
    
    bool book(int startTime, int endTime){
        map[startTime]++;
        map[endTime]+=-1;
        int count=0;
        for (auto it = map.begin(); it != map.end(); ++it){ //for (auto &it : mp)
            count+=it->second;
            if(count>=3){
                map[startTime]--;if(map[startTime]==0)map.erase(startTime);
                map[endTime]++;if(map[endTime]==0)map.erase(endTime);
                return false;}
        }
        return true;
        
        
        
    


    }
};

