class MyCalendar {
public:
    //Line Sweep Algorithm
    map<int,int>mp; 
    MyCalendar() {
        
    }
    
    bool book(int startTime, int endTime) {
        mp[startTime]++;
        mp[endTime]--;
        int count=0;
        for (auto it = mp.begin(); it != mp.end(); ++it){
            count+=it->second;
            if(count>=2){
                mp[startTime]--;if(mp[startTime]==0)mp.erase(startTime);
                mp[endTime]++;if(mp[endTime]==0)mp.erase(endTime);
                return false;

            }
        } 
        return true;
             

        
    }
};

