//Time-o(logn)
//space-o(1)
class Solution {
    findCeil(nums, target) {
        let i = 0;
        let j = nums.length - 1;
        let ans = -1;

        while (i <= j) {
            let mid = i + Math.floor((j - i) / 2);

            if (nums[mid] >= target) {
                ans = mid;      // possible ceil
                j = mid - 1;    // try to find smaller >= target
            } else {
                i = mid + 1;
            }
        }
        return ans;
    }
}
