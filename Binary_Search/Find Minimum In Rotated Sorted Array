//using Binary Search
//Time-O(logn)
//Space-O(1)
var findMin = function(nums) {
    let i=0;
    let j=nums.length-1;
    while(i<j){
        let mid= i+ Math.floor((j-i)/2);
        if(nums[mid]>nums[j]){
            i=mid+1;
        }
        else{
            j=mid;

        }
    }
    return nums[i];
};
