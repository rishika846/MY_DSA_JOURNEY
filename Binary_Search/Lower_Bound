class Solution {
  public:
    int lowerBound(vector<int>& nums, int target) {
        // code here
        int n =nums.size();
        int i=0;
        int j=n-1;
        int res=nums.size();
        while(i<=j){
            int mid=i+(j-i)/2;
            if(nums[mid]>=target){
                res=mid;
                j=mid-1;
            }
            else{
                i=mid+1;
            }
        }
        return res;
    }
};
