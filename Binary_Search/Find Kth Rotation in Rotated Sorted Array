//Time-o(logn)
//space-O(1)
class Solution {
    findKRotation(nums) {
        // Code Here
        let i=0;
    let j=nums.length-1;
    while(i<j){
        let mid= i+ Math.floor((j-i)/2);
        if(nums[mid]>nums[j]){
            i=mid+1;
        }
        else{
            j=mid;

        }
    }
    return i;
        
    }
}
