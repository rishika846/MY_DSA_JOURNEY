class Solution {
 
  public:
    long long countTriplets(int n, long long target, long long nums[]) {
        // Your code goes here
        long long count=0;
        sort(nums,nums+n);
        for(int i=0;i<n-2;i++){
            int left=i+1;
            int right=n-1;
            while(left<right){
                long long sum=nums[i]+nums[left]+nums[right];
                if(sum<target){
                 count+=right-left;
                 left++;
                 
                    
                    
                }
                else{
                    right--;
                }
            }
        }
        return count;
    }
};
